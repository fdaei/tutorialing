generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  STAFF
  EXAMINER
  SUPPORT
  FINANCE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum TeacherStatus {
  DRAFT
  SUBMITTED
  DOCUMENT_REVIEW
  INTERVIEW
  DEMO_REVIEW
  APPROVED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum TestStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SCORED
  UNDER_REVIEW
  APPROVED
  EXPIRED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  WAITING_SUPPORT
  RESOLVED
  CLOSED
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum CreditEntryType {
  PURCHASE
  RESERVE
  CONSUME
  RESTORE
  EXPIRE
  ADJUST
}

enum EarningStatus {
  PENDING
  ELIGIBLE
  HELD
  DISPUTED
  PAID
}

enum PayoutStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  TRANSFERRED
  FAILED
}

enum NotificationChannel {
  IN_APP
  SMS
}

enum FileStatus {
  PENDING
  SAFE
  QUARANTINED
  DELETED
}

enum LanguageDirection {
  LTR
  RTL
}

enum ProficiencySystem {
  CEFR
  CUSTOM
}

enum DocumentStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum PriceStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  COUNTER_OFFER
  APPROVED
  REJECTED
}

enum AnswerReviewStatus {
  PENDING
  IN_REVIEW
  APPROVED
  NEEDS_REVISION
}

enum TicketMessageType {
  USER_MESSAGE
  STAFF_REPLY
  INTERNAL_NOTE
  SYSTEM
}

enum TicketDirection {
  INBOUND
  OUTBOUND
  INTERNAL
  SYSTEM
}

model User {
  id                      String                    @id @default(cuid())
  phone                   String                    @unique
  name                    String?
  email                   String?
  avatarKey               String?
  locale                  String                    @default("fa")
  timezone                String                    @default("Asia/Tehran")
  profileComplete         Boolean                   @default(false)
  status                  UserStatus                @default(ACTIVE)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  roles                   UserRole[]
  sessions                RefreshSession[]
  otpChallenges           OtpChallenge[]
  teacher                 Teacher?
  bookings                Booking[]
  attempts                TestAttempt[]
  matches                 MatchingSession[]
  favorites               Favorite[]
  payments                Payment[]
  walletEntries           WalletEntry[]
  enrollments             Enrollment[]
  tickets                 Ticket[]
  notifications           Notification[]
  preferences             NotificationPreference[]
  learningPlans           LearningPlan[]            @relation("StudentPlans")
  submittedReviews        Review[]                  @relation("StudentReviews")
  moderatedReviews        Review[]                  @relation("ReviewModerator")
  teacherPricesReviewed   Teacher[]                 @relation("TeacherPriceReviewer")
  teacherPriceActions     TeacherPriceHistory[]     @relation("TeacherPriceActor")
  reviewedAnswers         TestAnswer[]              @relation("AnswerReviewer")
  assignedTickets         Ticket[]                  @relation("TicketAssignee")
  ticketReplies           TicketReply[]             @relation("TicketReplyAuthor")
  ticketStatusActions     TicketStatusHistory[]     @relation("TicketStatusActor")
  ticketAssignmentActions TicketAssignmentHistory[] @relation("TicketAssignmentActor")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String
  roles       RolePermission[]
}

model UserRole {
  userId      String
  role        Role
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions RolePermission[]

  @@id([userId, role])
}

model RolePermission {
  userId       String
  role         Role
  permissionId String
  userRole     UserRole   @relation(fields: [userId, role], references: [userId, role], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, role, permissionId])
}

model RefreshSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId     String
  tokenHash    String
  expiresAt    DateTime
  replacedById String?
  revokedAt    DateTime?
  ip           String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  @@index([userId, familyId])
}

model OtpChallenge {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  phone       String
  codeHash    String
  expiresAt   DateTime
  attempts    Int       @default(0)
  resendAfter DateTime
  createdAt   DateTime  @default(now())
  verifiedAt  DateTime?

  @@index([phone, createdAt])
}

model Teacher {
  id                    String                   @id @default(cuid())
  userId                String                   @unique
  user                  User                     @relation(fields: [userId], references: [id])
  slug                  String                   @unique
  nameFa                String
  nameEn                String
  bioFa                 String
  bioEn                 String
  status                TeacherStatus            @default(DRAFT)
  rating                Float                    @default(0)
  reviewsCount          Int                      @default(0)
  experienceYears       Int                      @default(0)
  gender                String?
  trialPrice            Int                      @default(0)
  regularPrice          Int                      @default(0)
  trialDuration         Int                      @default(30)
  lessonDuration        Int                      @default(60)
  breakMinutes          Int                      @default(15)
  proposedTrialPrice    Int?
  proposedRegularPrice  Int?
  approvedTrialPrice    Int?
  approvedRegularPrice  Int?
  counterTrialPrice     Int?
  counterRegularPrice   Int?
  priceStatus           PriceStatus              @default(DRAFT)
  priceReviewedById     String?
  priceReviewedBy       User?                    @relation("TeacherPriceReviewer", fields: [priceReviewedById], references: [id])
  priceReviewedAt       DateTime?
  priceReviewNote       String?
  specialties           String[]
  languages             String[]
  targetBands           Float[]
  introVideoKey         String?
  policyId              String?
  policy                CancellationPolicy?      @relation(fields: [policyId], references: [id])
  submittedAt           DateTime?
  approvedAt            DateTime?
  verificationItems     VerificationItem[]
  verificationHistory   VerificationHistory[]
  languageLinks         TeacherLanguage[]
  priceHistory          TeacherPriceHistory[]
  availabilityRules     AvailabilityRule[]
  availabilityOverrides AvailabilityOverride[]
  blockedPeriods        BlockedPeriod[]
  bookings              Booking[]
  packages              Package[]
  reviews               Review[]
  matches               MatchingRecommendation[]
  earnings              Earning[]
  learningPlans         LearningPlan[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
}

model VerificationItem {
  id              String         @id @default(cuid())
  teacherId       String
  teacher         Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  kind            String
  status          DocumentStatus @default(DRAFT)
  fileId          String?
  file            StoredFile?    @relation(fields: [fileId], references: [id])
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  note            String?
  submittedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model VerificationHistory {
  id         String         @id @default(cuid())
  teacherId  String
  teacher    Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  fromStatus TeacherStatus?
  toStatus   TeacherStatus
  actorId    String
  note       String?
  createdAt  DateTime       @default(now())
}

model Review {
  id               String       @id @default(cuid())
  teacherId        String
  teacher          Teacher      @relation(fields: [teacherId], references: [id])
  studentId        String
  student          User         @relation("StudentReviews", fields: [studentId], references: [id])
  bookingId        String       @unique
  booking          Booking      @relation(fields: [bookingId], references: [id])
  rating           Int
  comment          String?
  moderationStatus ReviewStatus @default(PENDING)
  published        Boolean      @default(false)
  moderatedById    String?
  moderatedBy      User?        @relation("ReviewModerator", fields: [moderatedById], references: [id])
  moderatedAt      DateTime?
  rejectionReason  String?
  teacherResponse  String?
  respondedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Favorite {
  userId    String
  teacherId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, teacherId])
}

model CancellationPolicy {
  id           String    @id @default(cuid())
  titleFa      String
  titleEn      String
  rules        Json
  active       Boolean   @default(true)
  approvedById String?
  teachers     Teacher[]
}

model AvailabilityRule {
  id             String  @id @default(cuid())
  teacherId      String
  teacher        Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  weekday        Int
  startMinute    Int
  endMinute      Int
  timezone       String
  lessonDuration Int?
  breakMinutes   Int?
  active         Boolean @default(true)

  @@index([teacherId, weekday])
}

model AvailabilityOverride {
  id            String   @id @default(cuid())
  teacherId     String
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  date          DateTime
  startMinute   Int?
  endMinute     Int?
  available     Boolean
  reason        String?
  adminOverride Boolean  @default(false)

  @@unique([teacherId, date])
  @@index([teacherId, date])
}

model BlockedPeriod {
  id           String   @id @default(cuid())
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  startsAt     DateTime
  endsAt       DateTime
  reason       String?
  adminCreated Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([teacherId, startsAt, endsAt])
}

model Booking {
  id                 String           @id @default(cuid())
  studentId          String
  student            User             @relation(fields: [studentId], references: [id])
  teacherId          String
  teacher            Teacher          @relation(fields: [teacherId], references: [id])
  enrollmentId       String?
  enrollment         Enrollment?      @relation(fields: [enrollmentId], references: [id])
  startsAt           DateTime
  endsAt             DateTime
  timezone           String
  type               String
  status             BookingStatus    @default(PENDING_PAYMENT)
  price              Int
  policySnapshot     Json
  paymentExpiresAt   DateTime?
  meetingUrl         String?
  attendanceStudent  Boolean?
  attendanceTeacher  Boolean?
  cancelledAt        DateTime?
  cancellationReason String?
  payment            Payment?
  creditReservations CreditEntry[]
  classRecord        ClassRecord?
  trialEvaluation    TrialEvaluation?
  earning            Earning?
  review             Review?
  reminders          Reminder[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([teacherId, startsAt, endsAt])
  @@index([studentId, startsAt, endsAt])
}

model ClassRecord {
  id          String    @id @default(cuid())
  bookingId   String    @unique
  booking     Booking   @relation(fields: [bookingId], references: [id])
  notes       String?
  completedAt DateTime?
}

model Package {
  id              String                  @id @default(cuid())
  teacherId       String
  teacher         Teacher                 @relation(fields: [teacherId], references: [id])
  titleFa         String
  titleEn         String
  descriptionFa   String
  descriptionEn   String
  credits         Int
  lessonMinutes   Int
  price           Int
  active          Boolean                 @default(true)
  approvalStatus  ReviewStatus            @default(PENDING)
  approvedById    String?
  enrollments     Enrollment[]
  recommendations PackageRecommendation[]
  createdAt       DateTime                @default(now())
}

model Enrollment {
  id               String        @id @default(cuid())
  studentId        String
  student          User          @relation(fields: [studentId], references: [id])
  packageId        String
  package          Package       @relation(fields: [packageId], references: [id])
  creditsPurchased Int
  expiresAt        DateTime?
  active           Boolean       @default(true)
  creditEntries    CreditEntry[]
  bookings         Booking[]
  paymentId        String?
  createdAt        DateTime      @default(now())
}

model CreditEntry {
  id             String          @id @default(cuid())
  enrollmentId   String
  enrollment     Enrollment      @relation(fields: [enrollmentId], references: [id])
  bookingId      String?
  booking        Booking?        @relation(fields: [bookingId], references: [id])
  type           CreditEntryType
  amount         Int
  idempotencyKey String          @unique
  note           String?
  createdAt      DateTime        @default(now())

  @@index([enrollmentId, createdAt])
}

model TrialEvaluation {
  id                   String   @id @default(cuid())
  bookingId            String   @unique
  booking              Booking  @relation(fields: [bookingId], references: [id])
  teacherId            String
  studentId            String
  currentBand          Float?
  weakSkills           String[]
  notes                String
  recommendedPackageId String?
  createdAt            DateTime @default(now())
}

model PackageRecommendation {
  id        String   @id @default(cuid())
  teacherId String
  studentId String
  packageId String
  package   Package  @relation(fields: [packageId], references: [id])
  reason    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model LearningPlan {
  id          String       @id @default(cuid())
  studentId   String
  student     User         @relation("StudentPlans", fields: [studentId], references: [id])
  teacherId   String
  teacher     Teacher      @relation(fields: [teacherId], references: [id])
  title       String
  targetBand  Float
  examDate    DateTime?
  weakSkills  String[]
  status      String       @default("active")
  milestones  Milestone[]
  assignments Assignment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Milestone {
  id          String       @id @default(cuid())
  planId      String
  plan        LearningPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title       String
  dueAt       DateTime?
  completedAt DateTime?
  order       Int
}

model Assignment {
  id           String       @id @default(cuid())
  planId       String
  plan         LearningPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title        String
  instructions String
  dueAt        DateTime?
  status       String       @default("pending")
  submission   String?
  feedback     String?
  score        Float?
}

model Payment {
  id               String           @id @default(cuid())
  bookingId        String?          @unique
  booking          Booking?         @relation(fields: [bookingId], references: [id])
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  purpose          String
  referenceId      String
  subtotal         Int
  discountAmount   Int              @default(0)
  walletAmount     Int              @default(0)
  gatewayAmount    Int
  amount           Int
  status           PaymentStatus    @default(PENDING)
  authority        String?          @unique
  gatewayReference String?
  idempotencyKey   String           @unique
  callbackPayload  Json?
  verifiedAt       DateTime?
  refunds          Refund[]
  reconciliations  Reconciliation[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model WalletEntry {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  transactionId  String
  account        String
  direction      LedgerDirection
  amount         Int
  description    String
  referenceType  String
  referenceId    String
  idempotencyKey String          @unique
  createdAt      DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([transactionId])
}

model Discount {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String
  value     Int
  maxUses   Int?
  usedCount Int       @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  active    Boolean   @default(true)
}

model Refund {
  id               String   @id @default(cuid())
  paymentId        String
  payment          Payment  @relation(fields: [paymentId], references: [id])
  amount           Int
  reason           String
  status           String   @default("pending")
  gatewayReference String?
  idempotencyKey   String   @unique
  approvedById     String?
  createdAt        DateTime @default(now())
}

model Reconciliation {
  id             String   @id @default(cuid())
  paymentId      String
  payment        Payment  @relation(fields: [paymentId], references: [id])
  providerAmount Int
  providerStatus String
  matched        Boolean
  details        Json?
  createdAt      DateTime @default(now())
}

model Earning {
  id               String        @id @default(cuid())
  teacherId        String
  teacher          Teacher       @relation(fields: [teacherId], references: [id])
  bookingId        String        @unique
  booking          Booking       @relation(fields: [bookingId], references: [id])
  grossAmount      Int
  commissionAmount Int
  netAmount        Int
  status           EarningStatus @default(PENDING)
  eligibleAt       DateTime
  payoutItem       PayoutItem?
  createdAt        DateTime      @default(now())
}

model PayoutBatch {
  id            String       @id @default(cuid())
  weekStart     DateTime
  weekEnd       DateTime
  status        PayoutStatus @default(DRAFT)
  totalAmount   Int          @default(0)
  approvedById  String?
  approvedAt    DateTime?
  transferredAt DateTime?
  reference     String?
  items         PayoutItem[]
  createdAt     DateTime     @default(now())
}

model PayoutItem {
  id        String      @id @default(cuid())
  batchId   String
  batch     PayoutBatch @relation(fields: [batchId], references: [id])
  earningId String      @unique
  earning   Earning     @relation(fields: [earningId], references: [id])
  teacherId String
  amount    Int
}

model TestDefinition {
  id              String        @id @default(cuid())
  slug            String        @unique
  languageId      String        @default("lang-en")
  language        Language      @relation(fields: [languageId], references: [id])
  level           String?
  titleFa         String
  titleEn         String
  descriptionFa   String
  descriptionEn   String
  version         Int           @default(1)
  published       Boolean       @default(false)
  durationMinutes Int
  sections        TestSection[]
  attempts        TestAttempt[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([languageId, published])
}

model TestSection {
  id              String         @id @default(cuid())
  testId          String
  test            TestDefinition @relation(fields: [testId], references: [id], onDelete: Cascade)
  skill           String
  title           String
  instructions    Json
  durationMinutes Int
  order           Int
  lockAfterSubmit Boolean        @default(true)
  passages        Passage[]
  questions       Question[]

  @@unique([testId, order])
}

model Passage {
  id          String      @id @default(cuid())
  sectionId   String
  section     TestSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title       String
  content     Json
  audioFileId String?
  audioFile   StoredFile? @relation("PassageAudio", fields: [audioFileId], references: [id])
  order       Int
}

model Question {
  id          String       @id @default(cuid())
  sectionId   String
  section     TestSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  passageId   String?
  prompt      Json
  type        String
  choices     Json?
  answerKey   Json?
  scoringRule Json?
  audioFileId String?
  audioFile   StoredFile?  @relation("QuestionAudio", fields: [audioFileId], references: [id])
  points      Float        @default(1)
  order       Int
  answers     TestAnswer[]

  @@unique([sectionId, order])
}

model TestAttempt {
  id               String                @id @default(cuid())
  userId           String
  user             User                  @relation(fields: [userId], references: [id])
  testId           String
  test             TestDefinition        @relation(fields: [testId], references: [id])
  status           TestStatus            @default(IN_PROGRESS)
  currentSectionId String?
  startedAt        DateTime              @default(now())
  expiresAt        DateTime
  lastSavedAt      DateTime              @default(now())
  submittedAt      DateTime?
  answers          TestAnswer[]
  sectionStates    AttemptSectionState[]
  scores           TestScore[]
  reviews          ExaminerReview[]
  overallBand      Float?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([userId, createdAt])
}

model AttemptSectionState {
  id               String      @id @default(cuid())
  attemptId        String
  attempt          TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  sectionId        String
  status           String      @default("available")
  startedAt        DateTime?
  submittedAt      DateTime?
  remainingSeconds Int
  flags            String[]    @default([])

  @@unique([attemptId, sectionId])
}

model TestAnswer {
  id              String              @id @default(cuid())
  attemptId       String
  attempt         TestAttempt         @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId      String
  question        Question            @relation(fields: [questionId], references: [id])
  value           Json?
  textValue       String?
  fileId          String?
  file            StoredFile?         @relation(fields: [fileId], references: [id])
  flagged         Boolean             @default(false)
  autoScore       Float?
  finalScore      Float?
  reviewStatus    AnswerReviewStatus?
  reviewCriteria  Json?
  feedbackFa      String?
  feedbackEn      String?
  reviewerId      String?
  reviewer        User?               @relation("AnswerReviewer", fields: [reviewerId], references: [id])
  reviewedAt      DateTime?
  examinerReviews ExaminerReview[]
  updatedAt       DateTime            @updatedAt

  @@unique([attemptId, questionId])
}

model TestScore {
  id           String      @id @default(cuid())
  attemptId    String
  attempt      TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  skill        String
  autoBand     Float?
  aiBand       Float?
  finalBand    Float?
  criteria     Json?
  feedback     String?
  approvedById String?
  approvedAt   DateTime?

  @@unique([attemptId, skill])
}

model ExaminerReview {
  id         String             @id @default(cuid())
  attemptId  String
  attempt    TestAttempt        @relation(fields: [attemptId], references: [id])
  examinerId String
  answerId   String?
  answer     TestAnswer?        @relation(fields: [answerId], references: [id], onDelete: Cascade)
  skill      String
  band       Float
  criteria   Json
  feedback   String
  feedbackFa String?
  feedbackEn String?
  status     AnswerReviewStatus @default(PENDING)
  approved   Boolean            @default(false)
  reviewedAt DateTime?
  createdAt  DateTime           @default(now())

  @@index([attemptId, status])
  @@index([answerId])
}

model MatchingSession {
  id                     String                   @id @default(cuid())
  userId                 String
  user                   User                     @relation(fields: [userId], references: [id])
  languageId             String                   @default("lang-en")
  language               Language                 @relation(fields: [languageId], references: [id])
  currentLevel           String?
  learningGoal           String?
  targetLevel            String?
  targetBand             Float
  currentBand            Float?
  examDate               DateTime?
  weakSkills             String[]
  maxTrialPrice          Int
  availability           Json
  suitableDays           Int[]                    @default([])
  preferredTime          String?
  preferredTeacherGender String?
  trialRequired          Boolean                  @default(true)
  classType              String                   @default("private")
  timezone               String
  recommendations        MatchingRecommendation[]
  createdAt              DateTime                 @default(now())

  @@index([languageId, createdAt])
}

model MatchingRecommendation {
  id        String          @id @default(cuid())
  sessionId String
  session   MatchingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   Teacher         @relation(fields: [teacherId], references: [id])
  rank      Int
  score     Float
  reasons   Json
  audit     Json
  createdAt DateTime        @default(now())

  @@unique([sessionId, rank])
}

model StoredFile {
  id                String             @id @default(cuid())
  ownerId           String
  key               String             @unique
  originalName      String
  mimeType          String
  size              Int
  checksum          String
  status            FileStatus         @default(PENDING)
  purpose           String
  verificationItems VerificationItem[]
  testAnswers       TestAnswer[]
  passageAudio      Passage[]          @relation("PassageAudio")
  questionAudio     Question[]         @relation("QuestionAudio")
  createdAt         DateTime           @default(now())
}

model Notification {
  id         String                 @id @default(cuid())
  userId     String
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  titleFa    String
  titleEn    String
  bodyFa     String
  bodyEn     String
  data       Json?
  readAt     DateTime?
  deliveries NotificationDelivery[]
  createdAt  DateTime               @default(now())

  @@index([userId, createdAt])
}

model NotificationDelivery {
  id               String              @id @default(cuid())
  notificationId   String
  notification     Notification        @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel          NotificationChannel
  status           String
  attempts         Int                 @default(0)
  providerId       String?
  providerResponse Json?
  scheduledAt      DateTime?
  sentAt           DateTime?
  createdAt        DateTime            @default(now())
}

model NotificationPreference {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   String
  inApp  Boolean @default(true)
  sms    Boolean @default(true)

  @@unique([userId, type])
}

model Reminder {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  type        String
  status      String   @default("scheduled")
  attempts    Int      @default(0)

  @@unique([bookingId, type])
}

model Ticket {
  id                String                    @id @default(cuid())
  userId            String
  user              User                      @relation(fields: [userId], references: [id])
  subject           String
  category          String
  priority          String
  status            TicketStatus              @default(OPEN)
  assignedToId      String?
  assignedTo        User?                     @relation("TicketAssignee", fields: [assignedToId], references: [id])
  slaDueAt          DateTime?
  lastReplyAt       DateTime?
  replies           TicketReply[]
  statusHistory     TicketStatusHistory[]
  assignmentHistory TicketAssignmentHistory[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([status, updatedAt])
  @@index([assignedToId, status])
}

model TicketReply {
  id           String            @id @default(cuid())
  ticketId     String
  ticket       Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId     String
  author       User              @relation("TicketReplyAuthor", fields: [authorId], references: [id])
  authorRole   Role
  direction    TicketDirection
  messageType  TicketMessageType
  body         String
  attachmentId String?
  internal     Boolean           @default(false)
  createdAt    DateTime          @default(now())

  @@index([ticketId, createdAt])
}

model Language {
  id                String            @id @default(cuid())
  code              String            @unique
  nameFa            String
  nameEn            String
  nativeName        String
  flag              String?
  direction         LanguageDirection @default(LTR)
  active            Boolean           @default(true)
  order             Int               @default(0)
  proficiencySystem ProficiencySystem @default(CEFR)
  teachers          TeacherLanguage[]
  tests             TestDefinition[]
  matchingSessions  MatchingSession[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([active, order])
}

model TeacherLanguage {
  teacherId   String
  languageId  String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  language    Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  levels      String[] @default([])
  specialties String[] @default([])
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@id([teacherId, languageId])
  @@index([languageId, active])
}

model TeacherPriceHistory {
  id                   String      @id @default(cuid())
  teacherId            String
  teacher              Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  actorId              String
  actor                User        @relation("TeacherPriceActor", fields: [actorId], references: [id])
  actorRole            Role
  action               String
  status               PriceStatus
  proposedTrialPrice   Int?
  proposedRegularPrice Int?
  approvedTrialPrice   Int?
  approvedRegularPrice Int?
  counterTrialPrice    Int?
  counterRegularPrice  Int?
  note                 String?
  createdAt            DateTime    @default(now())

  @@index([teacherId, createdAt])
}

model TicketStatusHistory {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromStatus TicketStatus?
  toStatus   TicketStatus
  actorId    String
  actor      User          @relation("TicketStatusActor", fields: [actorId], references: [id])
  note       String?
  createdAt  DateTime      @default(now())

  @@index([ticketId, createdAt])
}

model TicketAssignmentHistory {
  id             String   @id @default(cuid())
  ticketId       String
  ticket         Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromAssigneeId String?
  toAssigneeId   String?
  actorId        String
  actor          User     @relation("TicketAssignmentActor", fields: [actorId], references: [id])
  note           String?
  createdAt      DateTime @default(now())

  @@index([ticketId, createdAt])
}

model CmsPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  titleFa   String
  titleEn   String
  contentFa Json
  contentEn Json
  seo       Json
  published Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     Json
  public    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId, createdAt])
}

/// Scalable translations for editable fields and additional locales. Existing
/// fa/en columns remain the migration-safe fast path for core public content.
model LocalizedContent {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  field      String
  locale     String
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId, field, locale])
  @@index([entityType, entityId])
  @@index([locale])
}
